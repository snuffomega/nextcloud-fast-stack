# ============================================================
# Nextcloud Fast Stack 2026 — Environment Variables
# ============================================================
# Copy: cp .env.example .env
# Fill in the required values below.
# Never commit .env to version control.
# ============================================================

# ── Required: change these before first run ───────────────────
POSTGRES_PASSWORD=change_me_strong_db_password
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change_me_admin_password

# ── Optional: defaults work out of the box ────────────────────

# Caddy host ports
# By default this stack publishes TLS on host port 443 (recommended).
# If you need an optional tunnel that forwards to a local HTTP port, you can
# configure that tunnel to forward to the host HTTP port below. HTTP is
# optional — TLS (443) is the primary supported mode.
CADDY_TLS_PORT=443
# Optional HTTP port for tunnels/reverse-proxies (and for the built-in Caddy
# healthcheck). Leave empty to disable the extra port binding.
#CADDY_HTTP_PORT=8080

# Database
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud

# Timezone
TZ=America/New_York

# Hostnames (primary install domain plus tunnel/local variants)
# `NEXTCLOUD_DOMAIN` is the canonical hostname where the initial TLS tunnel lands.
# The Compose file automatically appends any values provided here for
# `NEXTCLOUD_EXTERNAL_HOST` and `NEXTCLOUD_LOCAL_HOST` to `NEXTCLOUD_TRUSTED_DOMAINS`
# so both tunnel and local TLS hosts work without extra `occ` tweaks.
NEXTCLOUD_DOMAIN=nextcloud.yourdomain.com
NEXTCLOUD_EXTERNAL_HOST=nextcloud.yourdomain.com
# `NEXTCLOUD_LOCAL_HOST` is optional; leave empty if you do not expose a local HTTPS host.
NEXTCLOUD_LOCAL_HOST=nextcloud.local

# Automatically set protocol override after installation. Set to "https" when
# the stack is reached over TLS (either via tunnel or local Caddy). Leave empty
# to skip changing the setting.
OVERWRITEPROTOCOL=https

# Enable automatic post-install `occ` fixes (db indices, maintenance repairs, defaults).
# Set to "false" to skip running the init helper service.
AUTO_INIT=true

# ── Optional: Restic backups — uncomment nextcloud-backup in docker-compose.yml ──
# BACKUP_PASSWORD=change-me-strong-passphrase   # required — encrypts all backups
# BACKUP_REPOSITORY=/backups/nextcloud           # or s3/b2/sftp URI (see compose comments)
# BACKUP_LOCAL_PATH=./data/backups              # host path for local repos
# BACKUP_CRON=0 3 * * *                          # daily at 3am
