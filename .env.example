# ============================================================
# Nextcloud Fast Stack 2026 — Environment Variables
# ============================================================
# Copy: cp .env.example .env
# Fill in the required values below.
# Never commit .env to version control.
# ============================================================

# ── Required: change these before first run ───────────────────
POSTGRES_PASSWORD=change_me_strong_db_password
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change_me_admin_password

# ── Optional: defaults work out of the box ────────────────────

# Port Caddy listens on for homelab access (http://localhost:8080 or http://<your-ip>:8080).
# Change if another container already uses this port.
CADDY_PORT=8080

# Database
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud

# Timezone
TZ=America/New_York

# Domain/IP (required — Nextcloud's trusted domain list)
# ⚠️  IMPORTANT: This only applies during FIRST INSTALL.
# After installation, trusted_domains is saved to config.php.
# To add new domains/IPs later, use the occ command (see README).
# Without protocol. Examples for homelab:
#   localhost
#   192.168.1.100
#   10.0.0.50
NEXTCLOUD_DOMAIN=localhost

# ── Optional: Restic backups — uncomment nextcloud-backup in docker-compose.yml ──
# BACKUP_PASSWORD=change-me-strong-passphrase   # required — encrypts all backups
# BACKUP_REPOSITORY=/backups/nextcloud           # or s3/b2/sftp URI (see compose comments)
# BACKUP_LOCAL_PATH=./data/backups              # host path for local repos
# BACKUP_CRON=0 3 * * *                          # daily at 3am
