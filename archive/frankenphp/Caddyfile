# FrankenPHP Caddyfile — Nextcloud Fast Stack 2026
# FrankenPHP serves PHP natively in-process (no FPM socket).
# SERVER_NAME is set via the environment in docker-compose.yml.

# FrankenPHP Caddyfile -- Nextcloud Fast Stack 2026
# Internal-only: no TLS, no public ports.
# SERVER_NAME is set to ":CADDY_PORT" in docker-compose.yml.
# Your reverse proxy connects to caddy:CADDY_PORT on the Docker network.

{
    frankenphp
    order php_server before file_server
    auto_https off

    # -- Worker mode (uncomment for ~40% throughput improvement) --
    # Keeps PHP processes alive between requests, eliminating per-request
    # bootstrap overhead. Test in staging first -- Nextcloud worker-mode
    # support is improving but not yet the default recommendation.
    #
    # frankenphp {
    #     worker /var/www/html/index.php
    # }
}

{$SERVER_NAME} {

    encode zstd gzip

    # ── Security headers ──────────────────────────────────────
    header {
        Strict-Transport-Security "max-age=15552000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        X-Permitted-Cross-Domain-Policies "none"
        X-Robots-Tag "noindex, nofollow"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "no-referrer"
        -X-Powered-By
    }

    # ── Well-known redirects ──────────────────────────────────
    redir /.well-known/carddav   /remote.php/dav 301
    redir /.well-known/caldav    /remote.php/dav 301
    redir /.well-known/webfinger /index.php/.well-known/webfinger 301
    redir /.well-known/nodeinfo  /index.php/.well-known/nodeinfo  301

    # ── Block sensitive paths ─────────────────────────────────
    @sensitive {
        path /.htaccess
        path /data/*
        path /config/*
        path /db_structure
        path /.xml
        path /README
        path /3rdparty/*
        path /lib/*
        path /templates/*
        path /occ
        path /console.php
    }
    respond @sensitive 403

    # ── FrankenPHP handler ────────────────────────────────────
    # php_server uses FrankenPHP's native in-process PHP engine.
    # This replaces php_fastcgi from the standard FPM path.
    root * /var/www/html

    php_server

    file_server
}
