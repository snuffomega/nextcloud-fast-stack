# Nextcloud Fast Stack 2026 -- Caddyfile
# Caddy proxies HTTP requests from :8080 to the Nextcloud PHP-FPM container.
# For HTTPS, use tunneling (Cloudflare/Tailscale) or uncomment the alt below for local TLS.

:8080 {

	encode zstd gzip

	# -- Security headers ----------------------------------------
	# TLS headers (HSTS, etc.) omitted — HTTP-only homelab setup.
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		X-Permitted-Cross-Domain-Policies "none"
		X-Robots-Tag "noindex, nofollow"
		Referrer-Policy "no-referrer"
		-X-Powered-By
	}

	# -- Well-known redirects ------------------------------------
	redir /.well-known/carddav   /remote.php/dav 301
	redir /.well-known/caldav    /remote.php/dav 301
	redir /.well-known/webfinger /index.php/.well-known/webfinger 301
	redir /.well-known/nodeinfo  /index.php/.well-known/nodeinfo  301

	# -- Block sensitive paths -----------------------------------
	@sensitive {
		path /.htaccess
		path /data/*
		path /config/*
		path /db_structure
		path /.xml
		path /README
		path /3rdparty/*
		path /lib/*
		path /templates/*
		path /occ
		path /console.php
	}
	respond @sensitive 403

	# -- PHP-FPM -------------------------------------------------
	root * /var/www/html

	php_fastcgi nextcloud:9000 {
		root /var/www/html
		env front_controller_active true
		env modHeadersAvailable true
		trusted_proxies private_ranges
	}

	file_server
}

# Alternative: Uncomment for native HTTPS (requires docker-compose.yml port change to 443)
# Replace the host/email below with the same value you put in NEXTCLOUD_DOMAIN
# and keep docker-compose binding on 443 when you enable this mode.
